# Gemini — used only as a local-dev fallback if a user has no key saved.
# For production, leave empty so every user brings their own via the settings modal.
GEMINI_API_KEY=

# Supabase — required for auth + database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
